                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction BT\n\n    %% --- PACKAGE MODEL ---\n    subgraph model\n        class Client {\n            -int id\n            -String nom\n            -String prenom\n            -String telephone\n            -String adresse\n            +getId() int\n            +getTelephone() String\n            +setId(int id) void\n            +setNom(String nom) void\n        }\n\n        class Compte {\n            -int id\n            -String numeroCompte\n            -double solde\n            -Client client\n            +getId() int\n            +getNumeroCompte() String\n            +getSolde() double\n            +setSolde(double solde) void\n        }\n\n        class Operation {\n            -int id\n            -TypeOperation typeOperation\n            -double montant\n            -LocalDateTime dateOperation\n            -String compteSource\n            -String compteDestination\n            -String marchand\n            +getId() int\n            +getTypeOperation() TypeOperation\n            +getMontant() double\n            +getDateOperation() LocalDateTime\n            +setDateOperation(LocalDateTime date) void\n        }\n\n        class TypeOperation {\n            &lt;&lt;enumeration&gt;&gt;\n            DEPOT\n            RETRAIT\n            TRANSFERT\n            PAIEMENT\n        }\n    end\n\n    %% --- PACKAGE DAO ---\n    subgraph dao\n        class DatabaseConnection {\n            +getConnection() Connection$\n        }\n\n        class ClientDAO {\n            +ajouter(Client client) void\n            +listerTous() List~Client~\n            +rechercherParTelephone(String tel) Client\n        }\n\n        class CompteDAO {\n            +creer(Compte compte) void\n            +consulterParNumero(String num) Compte\n            +afficherSolde(String num) void\n            +mettreAJourSolde(String num, double solde) void\n            +listerTous() List~Compte~\n        }\n\n        class OperationDAO {\n            +enregistrer(Operation op) void\n            +listerToutes() List~Operation~\n            +listerParCompte(String num) List~Operation~\n        }\n    end\n\n    %% --- PACKAGE SERVICE ---\n    subgraph service\n        class ServiceClient {\n            -ClientDAO clientDAO\n            +ajouterClient(String, String, String, String) void\n            +listerClients() void\n            +validerTelephone(String tel) boolean\n        }\n\n        class ServiceCompte {\n            -CompteDAO compteDAO\n            +creerCompte(int clientId) void\n            +consulterCompte(String num) void\n            +soldeEstSuffisant(String num, double mnt) boolean\n            +genererNumeroCompte(int id) String\n        }\n\n        class ServiceOperation {\n            -OperationDAO operationDAO\n            -CompteDAO compteDAO\n            -ServiceCompte serviceCompte\n            +effectuerDepot(String, double) void\n            +effectuerRetrait(String, double) void\n            +effectuerTransfert(String, String, double) void\n            +effectuerPaiement(String, String, double) void\n        }\n    end\n\n    %% --- PACKAGE INTERFACE ---\n    subgraph interfaceUtilisateur\n        class Menu {\n            -ServiceClient sClient\n            -ServiceCompte sCompte\n            -ServiceOperation sOperation\n            -Scanner scanner\n            +demarrer() void\n            -afficherMenu() void\n            -traiterChoix(int choix) void\n            -menuAjouterClient() void\n            -menuEffectuerTransfert() void\n        }\n    end\n\n    %% --- RELATIONS ---\n    Compte \&quot;0..*\&quot; --o \&quot;1\&quot; Client : appartient à\n    Operation --&gt; TypeOperation : type\n    \n    ClientDAO ..&gt; DatabaseConnection : utilise\n    CompteDAO ..&gt; DatabaseConnection : utilise\n    OperationDAO ..&gt; DatabaseConnection : utilise\n\n    ServiceClient --&gt; ClientDAO : manipule\n    ServiceCompte --&gt; CompteDAO : manipule\n    \n    ServiceOperation --&gt; OperationDAO : enregistre\n    ServiceOperation --&gt; CompteDAO : modifie solde\n    ServiceOperation --&gt; ServiceCompte : vérifie solde\n\n    Menu --&gt; ServiceClient : orchestre\n    Menu --&gt; ServiceCompte : orchestre\n    Menu --&gt; ServiceOperation : orchestre&quot;&#xa;}" id="95">
