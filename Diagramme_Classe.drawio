        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam packageStyle rectangle\nskinparam shadowing false\nskinparam linetype polyline\nskinparam nodesep 150\nskinparam ranksep 120\n\n&#39; --- STYLE DES FLECHES ---\nskinparam ArrowColor #2D3436\nskinparam ArrowThickness 1.2\n\n&#39; --- CLASSES ---\n\nclass Main #White {\n    + {static} main(args: String[]): void\n}\n\npackage \&quot;interfaceUtilisateur\&quot; #Lavender {\n    class Menu {\n        - sc: Scanner\n        - serviceClient: ServiceClient\n        - serviceCompte: ServiceCompte\n        - serviceOperation: ServiceOperation\n        + demarrer(): void\n        - menuGestionClients(): void\n        - menuGestionComptes(): void\n        - menuOperations(): void\n    }\n}\n\npackage \&quot;service\&quot; #LightBlue {\n    class ServiceOperation {\n        - compteDAO: CompteDAO\n        - operationDAO: OperationDAO\n        - marchandDAO: MarchandDAO\n        + effectuerDepot(num, mt): void\n        + effectuerRetrait(num, mt): void\n        + effectuerTransfert(src, dest, mt): void\n        + effectuerPaiement(num, codeM, mt): void\n        + listerOperationsParPeriode(debut, fin): List&lt;Operation&gt;\n        + afficherStatistiquesGlobales(): void\n    }\n    \n    class ServiceCompte {\n        - compteDAO: CompteDAO\n        - clientDAO: ClientDAO\n        + creerCompte(telephone, solde): void\n        + consulterSolde(numero): void\n    }\n    \n    class ServiceClient {\n        - clientDAO: ClientDAO\n        + creerClient(nom, prenom, tel, adr): void\n        + listerClients(): List&lt;Client&gt;\n    }\n}\n\npackage \&quot;dao\&quot; #PaleGreen {\n    class ClientDAO {\n        + creer(c: Client): int\n        + lister(): List&lt;Client&gt;\n        + trouverParTelephone(tel: String): Client\n    }\n    \n    class CompteDAO {\n        + creer(c: Compte): void\n        + consulterParNumero(num: String): Compte\n        + mettreAJourSolde(num: String, solde: double): boolean\n    }\n    \n    class MarchandDAO {\n        + listerTous(): List&lt;Marchand&gt;\n        + trouverParCode(code: String): Marchand\n    }\n    \n    class OperationDAO {\n        + enregistrer(op: Operation): void\n        + listerToutes(): List&lt;Operation&gt;\n        + listerParPeriode(d, f): List&lt;Operation&gt;\n    }\n}\n\npackage \&quot;model\&quot; #Wheat {\n    enum TypeOperation {\n        DEPOT\n        RETRAIT\n        TRANSFERT\n        PAIEMENT\n    }\n    \n    class Client {\n        - id: int\n        - nom: String\n        - prenom: String\n        - telephone: String\n        - adresse: String\n        + getId(): int\n        + setId(id: int): void\n        + getNom(): String\n        + setNom(nom: String): void\n        + getPrenom(): String\n        + setPrenom(prenom: String): void\n        + getTelephone(): String\n        + setTelephone(tel: String): void\n        + getAdresse(): String\n        + setAdresse(adr: String): void\n    }\n    \n    class Compte {\n        - id: int\n        - numeroCompte: String\n        - solde: double\n        - clientId: int\n        + getId(): int\n        + setId(id: int): void\n        + getNumeroCompte(): String\n        + setNumeroCompte(num: String): void\n        + getSolde(): double\n        + setSolde(solde: double): void\n        + getClientId(): int\n        + setClientId(id: int): void\n    }\n    \n    class Marchand {\n        - id: int\n        - nomEnseigne: String\n        - codeMarchand: String\n        + getId(): int\n        + setId(id: int): void\n        + getNomEnseigne(): String\n        + setNomEnseigne(nom: String): void\n        + getCodeMarchand(): String\n        + setCodeMarchand(code: String): void\n    }\n    \n    class Operation {\n        - id: int\n        - typeOperation: TypeOperation\n        - montant: double\n        - dateOperation: LocalDateTime\n        - compteSource: String\n        - compteDestination: String\n        - marchand: String\n        + getId(): int\n        + setId(id: int): void\n        + getTypeOperation(): TypeOperation\n        + setTypeOperation(type: TypeOperation): void\n        + getMontant(): double\n        + setMontant(mt: double): void\n        + getDateOperation(): LocalDateTime\n        + setDateOperation(d: LocalDateTime): void\n        + getCompteSource(): String\n        + setCompteSource(s: String): void\n        + getCompteDestination(): String\n        + setCompteDestination(d: String): void\n        + getMarchand(): String\n        + setMarchand(m: String): void\n    }\n}\n\npackage \&quot;database\&quot; #Silver {\n    class DatabaseConnection {\n        - {static} URL: String\n        - {static} USER: String\n        - {static} PASS: String\n        + {static} getConnection(): Connection\n    }\n}\n\n&#39; --- GESTION DES RELATIONS ET DES COURBES SYMÉTRIQUES ---\n\nMain .down.&gt; Menu : instancie\n\n&#39; Menu vers Services (Départ du bas du Menu vers le haut des services)\nMenu -[#blue]down-&gt; ServiceOperation\nMenu -[#blue]down-&gt; ServiceCompte\nMenu -[#blue]down-&gt; ServiceClient\n\n&#39; Services vers DAOs (Utilisation de ports différents pour éviter la superposition)\nServiceClient -[#green]down-&gt; ClientDAO\nServiceCompte -[#green]down-&gt; CompteDAO\nServiceCompte -[#green]down-&gt; ClientDAO\nServiceOperation -[#green]down-&gt; CompteDAO\nServiceOperation -[#green]down-&gt; OperationDAO\nServiceOperation -[#green]down-&gt; MarchandDAO\n\n&#39; DAOs vers Database (Regroupement symétrique vers DatabaseConnection)\nClientDAO -[#grey]down-&gt; DatabaseConnection\nCompteDAO -[#grey]down-&gt; DatabaseConnection\nOperationDAO -[#grey]down-&gt; DatabaseConnection\nMarchandDAO -[#grey]down-&gt; DatabaseConnection\n\n&#39; Relations Model (Déportées sur le côté pour ne pas croiser les services)\nOperation -right-&gt; TypeOperation\nCompte \&quot;0..*\&quot; -right-* \&quot;1\&quot; Client : appartient à\nOperation \&quot;0..*\&quot; -right-o \&quot;1\&quot; Compte : lié à\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_VeXffDjy25ONzV4v6ft-40">
